generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model game {
  id             Int               @id @default(autoincrement())
  sequenceNumber Int               @unique(map: "Game_sequenceNumber_key")
  title          String
  author         String
  coverUrl       String?
  commentId      Int?              @unique(map: "Game_commentId_key")
  rating         Int?
  genre          game_genre
  literaryForm   game_literaryForm
  lyricNote      String?           @db.Text
  createdAt      DateTime          @default(now())
  updatedAt      DateTime
  pageCount      Int
  gamelistitem   gamelistitem[]
  comment        comment[]
  ratings        rating[]
}

model gamelist {
  id           Int            @id @default(autoincrement())
  name         String
  userId       Int
  imagePath    String?        @db.Text
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  user         user           @relation(fields: [userId], references: [id], onDelete: Cascade, map: "GameList_userId_fkey")
  gamelistitem gamelistitem[]

  @@index([userId], map: "GameList_userId_fkey")
}

model gamelistitem {
  id                  Int                   @id @default(autoincrement())
  gameListId          Int
  gameId              Int
  createdAt           DateTime              @default(now())
  game                game                  @relation(fields: [gameId], references: [id], onDelete: Cascade, map: "GameListItem_gameId_fkey")
  gamelist            gamelist              @relation(fields: [gameListId], references: [id], onDelete: Cascade, map: "GameListItem_gameListId_fkey")
  gamelistitemgallery gamelistitemgallery[]

  @@unique([gameListId, gameId], map: "GameListItem_gameListId_gameId_key")
  @@index([gameId], map: "GameListItem_gameId_fkey")
}

model gamelistitemgallery {
  id             Int          @id @default(autoincrement())
  gameListItemId Int
  filePath       String       @db.Text
  fileType       String
  createdAt      DateTime     @default(now())
  gamelistitem   gamelistitem @relation(fields: [gameListItemId], references: [id], onDelete: Cascade, map: "GameListItemGallery_gameListItemId_fkey")

  @@index([gameListItemId], map: "GameListItemGallery_gameListItemId_fkey")
}

model comment {
  id          Int           @id @default(autoincrement())
  content     String        @db.Text
  userId      Int
  gameId      Int
  likes       Int           @default(0)
  dislikes    Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  game        game          @relation(fields: [gameId], references: [id], onDelete: Cascade, map: "Comment_gameId_fkey")
  user        user          @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Comment_userId_fkey")
  commentvote commentvote[]

  @@index([gameId], map: "Comment_gameId_fkey")
  @@index([userId], map: "Comment_userId_fkey")
}

model commentvote {
  id        Int      @id @default(autoincrement())
  userId    Int
  commentId Int
  isLike    Boolean
  createdAt DateTime @default(now())
  comment   comment  @relation(fields: [commentId], references: [id], onDelete: Cascade, map: "CommentVote_commentId_fkey")
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "CommentVote_userId_fkey")

  @@unique([userId, commentId], map: "CommentVote_userId_commentId_key")
  @@index([commentId], map: "CommentVote_commentId_fkey")
}

model devlogentry {
  id         Int        @id @default(autoincrement())
  title      String
  content    String     @db.Text
  projectId  Int
  imagePath  String?    @db.Text
  createdAt  DateTime   @default(now())
  updatedAt  DateTime
  devproject devproject @relation(fields: [projectId], references: [id], onDelete: Cascade, map: "DevLogEntry_projectId_fkey")

  @@index([projectId], map: "DevLogEntry_projectId_fkey")
}

model devproject {
  id           Int                     @id @default(autoincrement())
  name         String
  genre        devproject_genre
  literaryForm devproject_literaryForm
  description  String                  @db.Text
  imagePath    String?                 @db.Text
  developerId  Int
  createdAt    DateTime                @default(now())
  updatedAt    DateTime
  devlogentry  devlogentry[]
  favorites    devprojectfavorite[]
  upvotes      devprojectwishlist[]
  user         user                    @relation(fields: [developerId], references: [id], onDelete: Cascade, map: "DevProject_developerId_fkey")

  @@index([developerId], map: "DevProject_developerId_fkey")
}

model rating {
  id        Int      @id @default(autoincrement())
  rating    Int
  userId    Int
  gameId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime
  game      game     @relation(fields: [gameId], references: [id], onDelete: Cascade, map: "Rating_gameId_fkey")
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Rating_userId_fkey")

  @@unique([userId, gameId], map: "Rating_userId_gameId_key")
  @@index([gameId], map: "Rating_gameId_fkey")
}

model user {
  id           Int           @id @default(autoincrement())
  username     String        @unique(map: "User_username_key")
  email        String        @unique(map: "User_email_key")
  passwordHash String
  steamId      String?       @unique(map: "User_steamId_key")
  role         user_role     @default(USER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime
  gamelist     gamelist[]
  comment      comment[]
  commentvote  commentvote[]
  devproject   devproject[]
  rating       rating[]
  devfavorites devprojectfavorite[]
  devupvotes   devprojectwishlist[]
}

model devprojectfavorite {
  id        Int        @id @default(autoincrement())
  userId    Int
  projectId Int
  createdAt DateTime   @default(now())
  project   devproject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      user       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

model devprojectwishlist {
  id        Int        @id @default(autoincrement())
  userId    Int
  projectId Int
  createdAt DateTime   @default(now())
  project   devproject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      user       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

enum devproject_genre {
  ACTION
  PUZZLE
  RPG
  PLATFORMER
  HORROR
  ADVENTURE
  SANDBOX
  SIMULATION
  STRATEGY
  SPORTS
  RACING
  FIGHTING
  SHOOTER
  SURVIVAL
  STEALTH
  ROGUELIKE
  MOBA
  MMORPG
  TOWER_DEFENSE
  PARTY
  CARD_GAME
  RHYTHM
}

enum devproject_literaryForm {
  SINGLE_PLAYER
  MULTIPLAYER
  CO_OP
  BATTLE_ROYALE
  OPEN_WORLD
  LINEAR
  METROIDVANIA
  SOULSLIKE
  FIRST_PERSON
  THIRD_PERSON
  VR
  AUTOSHOOTER
  TEXT_BASED
}

enum user_role {
  USER
  DEVELOPER
  ADMIN
}

enum game_genre {
  ACTION
  PUZZLE
  RPG
  PLATFORMER
  HORROR
  ADVENTURE
  SANDBOX
  SIMULATION
  STRATEGY
  SPORTS
  RACING
  FIGHTING
  SHOOTER
  SURVIVAL
  STEALTH
  ROGUELIKE
  MOBA
  MMORPG
  TOWER_DEFENSE
  PARTY
  CARD_GAME
  RHYTHM
}

enum game_literaryForm {
  SINGLE_PLAYER
  MULTIPLAYER
  CO_OP
  BATTLE_ROYALE
  OPEN_WORLD
  LINEAR
  METROIDVANIA
  SOULSLIKE
  FIRST_PERSON
  THIRD_PERSON
  VR
  AUTOSHOOTER
  TEXT_BASED
}
