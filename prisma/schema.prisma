// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  DEVELOPER
  ADMIN
}

enum Genre {
  ACTION
  PUZZLE
  RPG
  PLATFORMER
  HORROR
  ADVENTURE
  SANDBOX
}

enum LiteraryForm {
  SINGLE_PLAYER
  MULTIPLAYER
  CO_OP
}

model User {
  id           Int        @id @default(autoincrement())
  username     String     @unique
  email        String     @unique
  passwordHash String
  steamId      String?    @unique
  role         Role       @default(USER)
  ratings      Rating[]
  comments     Comment[]
  bookLists    BookList[]
  projects     DevProject[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model DevProject {
  id          Int           @id @default(autoincrement())
  name        String
  category    String
  description String        @db.Text
  imageUrl    String?
  developerId Int
  developer   User          @relation(fields: [developerId], references: [id], onDelete: Cascade)
  entries     DevLogEntry[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model DevLogEntry {
  id          Int        @id @default(autoincrement())
  title       String
  content     String     @db.Text
  projectId   Int
  project     DevProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Book {
  id              Int             @id @default(autoincrement())
  sequenceNumber  Int             @unique
  title           String
  author          String
  coverUrl        String?
  commentId       Int?            @unique
  rating          Int?
  genre           Genre
  literaryForm    LiteraryForm
  lyricNote       String?         @db.Text
  ratings         Rating[]
  comments        Comment[]
  bookListItems   BookListItem[]
    
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  pageCount       Int
}

model Rating {
  id        Int      @id @default(autoincrement())
  rating    Int      // 1-5 csillag
  userId    Int
  bookId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, bookId]) // Egy user csak egyszer értékelhet egy könyvet
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  userId    Int
  bookId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BookList {
  id        Int            @id @default(autoincrement())
  name      String
  userId    Int
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     BookListItem[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model BookListItem {
  id         Int      @id @default(autoincrement())
  bookListId Int
  bookId     Int
  bookList   BookList @relation(fields: [bookListId], references: [id], onDelete: Cascade)
  book       Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([bookListId, bookId])
}
